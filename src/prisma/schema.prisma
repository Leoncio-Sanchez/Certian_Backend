// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["Admin", "Empresa", "Estudiante"]
}

// ===========================================================================
// ESQUEMA: Admin
// ===========================================================================

model UsuarioTipo {
  id_usuario_tipo  Int       @id @default(autoincrement()) @map("id_usuario_tipo")
  descripcion_tipo String    @map("descripcion_tipo") @db.VarChar(50)
  usuarios         Usuario[]

  @@map("USUARIO_TIPO")
  @@schema("Admin")
}

model Rol {
  id_rol     Int          @id @default(autoincrement()) @map("id_rol")
  nombre_rol String       @map("nombre_rol") @db.VarChar(100)
  usuarioRol UsuarioRol[]
  rolModulo  RolModulo[]

  @@map("ROL")
  @@schema("Admin")
}

model Modulo {
  id_modulo     Int         @id @default(autoincrement()) @map("id_modulo")
  nombre_modulo String      @map("nombre_modulo") @db.VarChar(100)
  rolModulo     RolModulo[]

  @@map("MODULO")
  @@schema("Admin")
}

model Usuario {
  id_usuario      Int         @id @default(autoincrement()) @map("id_usuario")
  id_usuario_tipo Int         @map("id_usuario_tipo")
  username        String      @unique @db.VarChar(100)
  password        String      @db.VarChar(100)
  estado_cuenta   Int?        @default(1) @map("estado_cuenta") @db.SmallInt
  
  usuarioTipo     UsuarioTipo @relation(fields: [id_usuario_tipo], references: [id_usuario_tipo], onUpdate: Restrict)
  usuarioRol      UsuarioRol[]
  
  // Relations to other schemas
  empresaProfile   Empresa?
  estudianteProfile Estudiante?

  @@map("USUARIO")
  @@schema("Admin")
}

model UsuarioRol {
  id_usuario_rol Int     @map("id_usuario_rol")
  id_rol         Int     @map("id_rol")
  usuario        Usuario @relation(fields: [id_usuario_rol], references: [id_usuario], onDelete: Cascade)
  rol            Rol     @relation(fields: [id_rol], references: [id_rol], onDelete: Cascade)

  @@id([id_usuario_rol, id_rol])
  @@map("USUARIO_ROL")
  @@schema("Admin")
}

model RolModulo {
  id_rol_modulo Int    @map("id_rol_modulo")
  id_modulo     Int    @map("id_modulo")
  rol           Rol    @relation(fields: [id_rol_modulo], references: [id_rol], onDelete: Cascade)
  modulo        Modulo @relation(fields: [id_modulo], references: [id_modulo], onDelete: Cascade)

  @@id([id_rol_modulo, id_modulo])
  @@map("ROL_MODULO")
  @@schema("Admin")
}

// ===========================================================================
// ESQUEMA: Empresa
// ===========================================================================

enum NivelNombreEnum {
  basico
  medio
  avanzado
  @@map("nivel_nombre_enum")
  @@schema("Empresa")
}

enum StatusEnum {
  activo
  inactivo
  @@map("status_enum")
  @@schema("Empresa")
}

enum EstadoRetoEnum {
  abierto
  cerrado
  @@map("estado_reto_enum")
  @@schema("Empresa")
}

enum EstadoPostulacionEnum {
  pendiente
  en_revision
  aprobado
  rechazado
  @@map("estado_postulacion_enum")
  @@schema("Empresa")
}

enum TipoAccionEnum {
  invitacion_entrevista
  seleccion_capacitacion
  propuesta_contratacion
  @@map("tipo_accion_enum")
  @@schema("Empresa")
}

enum EstadoProcesoEnum {
  pendiente
  aceptado
  rechazado
  @@map("estado_proceso_enum")
  @@schema("Empresa")
}

model NivelDificultad {
  id_nivel_dificultad Int             @id @default(autoincrement()) @map("id_nivel_dificultad")
  nombre             NivelNombreEnum @unique
  horas_por_defecto  Int             @map("horas_por_defecto")
  created_at         DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  retos              Reto[]

  @@map("NIVEL_DIFICULTAD")
  @@schema("Empresa")
}

model Empresa {
  id_empresa    Int        @id @default(autoincrement()) @map("id_empresa")
  id_usuario    Int        @unique @map("id_usuario")
  razon_social  String     @map("razon_social") @db.VarChar(150)
  ruc           String     @unique @db.VarChar(11)
  logo_url      String     @map("logo_url") @db.VarChar(255)
  rubro         String?    @db.VarChar(100)
  telefono      String?    @db.VarChar(20)
  status        StatusEnum? @default(activo)
  created_at    DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  
  usuario       Usuario    @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  retos         Reto[]
  interacciones InteraccionNetworking[]

  @@map("EMPRESA")
  @@schema("Empresa")
}

model Tema {
  id_tema      Int       @id @default(autoincrement()) @map("id_tema")
  nombre       String    @unique @db.VarChar(100)
  descripcion  String?
  created_at   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  retos        Reto[]

  @@map("TEMA")
  @@schema("Empresa")
}

model Reto {
  id_reto             Int               @id @default(autoincrement()) @map("id_reto")
  id_empresa          Int               @map("id_empresa")
  id_tema             Int               @map("id_tema")
  id_nivel_dificultad Int               @map("id_nivel_dificultad")
  titulo              String            @db.VarChar(150)
  descripcion_problema String           @map("descripcion_problema")
  requisitos_entrega   String           @map("requisitos_entrega")
  guia_pasos          String?           @map("guia_pasos")
  estado              EstadoRetoEnum?   @default(abierto)
  imagen_url          String?           @map("imagen_url") @db.VarChar(255)
  documento_url       String?           @map("documento_url") @db.VarChar(255)
  fecha_inicio        DateTime?         @map("fecha_inicio") @db.Date
  fecha_limite        DateTime?         @map("fecha_limite") @db.Date
  created_at          DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  
  empresa             Empresa           @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  tema                Tema              @relation(fields: [id_tema], references: [id_tema], onDelete: Restrict)
  nivel_dificultad    NivelDificultad   @relation(fields: [id_nivel_dificultad], references: [id_nivel_dificultad], onDelete: Restrict)
  postulaciones       Postulacion[]
  estudianteRetos     EstudianteReto[]
  pasos               PasoReto[]

  @@map("RETO")
  @@schema("Empresa")
}

model PasoReto {
  id_paso_reto  Int      @id @default(autoincrement()) @map("id_paso_reto")
  id_reto       Int      @map("id_reto")
  orden         Int      @map("orden")
  titulo        String   @db.VarChar(200)
  descripcion   String   @db.Text
  created_at    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  reto          Reto     @relation(fields: [id_reto], references: [id_reto], onDelete: Cascade)

  @@map("PASO_RETO")
  @@schema("Empresa")
}

model Postulacion {
  id_postulacion   Int                   @id @default(autoincrement()) @map("id_postulacion")
  id_reto          Int                   @map("id_reto")
  id_estudiante    Int                   @map("id_estudiante")
  repositorio_url  String?               @map("repositorio_url") @db.VarChar(255)
  solucion_url     String?               @map("solucion_url") @db.VarChar(255)
  estado           EstadoPostulacionEnum? @default(pendiente)
  feedback_tecnico String?               @map("feedback_tecnico")
  score_tech       Decimal?              @default(0.00) @map("score_tech") @db.Decimal(5, 2)
  fecha_inicio     DateTime?             @default(now()) @map("fecha_inicio") @db.Timestamp(6)
  fecha_entrega    DateTime?             @map("fecha_entrega") @db.Timestamp(6)
  updated_at       DateTime?             @default(now()) @map("updated_at") @db.Timestamp(6)
  
  reto             Reto                  @relation(fields: [id_reto], references: [id_reto], onDelete: Cascade)
  estudiante       Estudiante            @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade)
  certificado      Certificado?

  @@unique([id_estudiante, id_reto], map: "uq_estudiante_reto_postulacion")
  @@map("POSTULACION")
  @@schema("Empresa")
}

model Certificado {
  id_certificado     Int         @id @default(autoincrement()) @map("id_certificado")
  id_postulacion     Int         @unique @map("id_postulacion")
  codigo_verificacion String      @unique @map("codigo_verificacion") @db.VarChar(100)
  url_pdf            String      @map("url_pdf") @db.VarChar(255)
  fecha_emision      DateTime?   @default(now()) @map("fecha_emision") @db.Timestamp(6)
  
  postulacion        Postulacion @relation(fields: [id_postulacion], references: [id_postulacion], onDelete: Restrict)

  @@map("CERTIFICADO")
  @@schema("Empresa")
}

model InteraccionNetworking {
  id_interaccion_networking Int               @id @default(autoincrement()) @map("id_interaccion_networking")
  id_empresa               Int               @map("id_empresa")
  id_estudiante            Int               @map("id_estudiante")
  tipo_accion              TipoAccionEnum
  mensaje_convocatoria     String            @map("mensaje_convocatoria")
  estado_proceso           EstadoProcesoEnum? @default(pendiente) @map("estado_proceso")
  created_at               DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  
  empresa                  Empresa           @relation(fields: [id_empresa], references: [id_empresa], onDelete: Cascade)
  estudiante               Estudiante        @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade)

  @@map("INTERACCION_NETWORKING")
  @@schema("Empresa")
}

// ===========================================================================
// ESQUEMA: Estudiante
// ===========================================================================

model Habilidad {
  id_habilidad     Int                  @id @default(autoincrement()) @map("id_habilidad")
  nombre_habilidad String               @map("nombre_habilidad") @db.VarChar(100)
  categoria        String?              @db.VarChar(50)
  estudianteHabilidades EstudianteHabilidad[]

  @@map("HABILIDAD")
  @@schema("Estudiante")
}

model Estudiante {
  id_estudiante   Int                  @id @default(autoincrement()) @map("id_estudiante")
  id_usuario      Int                  @unique @map("id_usuario")
  dni             String               @unique @db.VarChar(15)
  nombres         String               @db.VarChar(100)
  apellidos       String               @db.VarChar(100)
  carrera         String               @db.VarChar(100)
  ciclo           String               @db.VarChar(20)
  correo_contacto String               @map("correo_contacto") @db.VarChar(100)
  telefono        String?              @db.VarChar(20)
  foto_perfil_url String?              @map("foto_perfil_url") @db.VarChar(255)
  puntos_ranking  Int?                 @default(0) @map("puntos_ranking")
  
  usuario         Usuario              @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  formacion       FormacionAcademica[]
  certificaciones Certificacion[]
  estudianteRetos EstudianteReto[]
  habilidades     EstudianteHabilidad[]
  postulaciones   Postulacion[]
  interacciones   InteraccionNetworking[]

  @@map("ESTUDIANTE")
  @@schema("Estudiante")
}

model FormacionAcademica {
  id_formacion_academica Int        @id @default(autoincrement()) @map("id_formacion_academica")
  id_estudiante         Int        @map("id_estudiante")
  universidad_instituto String     @map("universidad_instituto") @db.VarChar(150)
  estado_estudio        String     @map("estado_estudio") @db.VarChar(50)
  sello_universidad     Boolean?   @default(false) @map("sello_universidad")
  
  estudiante            Estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade)

  @@map("FORMACION_ACADEMICA")
  @@schema("Estudiante")
}

model Certificacion {
  id_certificacion    Int        @id @default(autoincrement()) @map("id_certificacion")
  id_estudiante       Int        @map("id_estudiante")
  nombre_certificado  String     @map("nombre_certificado") @db.VarChar(150)
  organizacion_emisora String     @map("organizacion_emisora") @db.VarChar(150)
  fecha_expedicion    DateTime   @map("fecha_expedicion") @db.Date
  url_credencial      String?    @map("url_credencial") @db.VarChar(200)
  
  estudiante          Estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade)

  @@map("CERTIFICACION")
  @@schema("Estudiante")
}

model EstudianteReto {
  id_estudiante_reto Int       @id @default(autoincrement()) @map("id_estudiante_reto")
  id_estudiante      Int       @map("id_estudiante")
  id_reto            Int       @map("id_reto")
  estado_desarrollo  String?   @default("En Progreso") @map("estado_desarrollo") @db.VarChar(50)
  fecha_inicio       DateTime? @default(now()) @map("fecha_inicio") @db.Date
  fecha_entrega      DateTime? @map("fecha_entrega") @db.Date
  solucion_texto_url String?   @map("solucion_texto_url")
  contacto_networking Boolean? @default(false) @map("contacto_networking")
  
  estudiante        Estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade)
  reto              Reto       @relation(fields: [id_reto], references: [id_reto], onDelete: Cascade)

  @@unique([id_estudiante, id_reto], map: "UQ_ESTUDIANTE_RETO_COMPUESTA")
  @@map("ESTUDIANTE_RETO")
  @@schema("Estudiante")
}

model PasoEvidencia {
  id_paso_evidencia  Int             @id @default(autoincrement()) @map("id_paso_evidencia")
  id_estudiante_reto Int             @map("id_estudiante_reto")
  id_paso_reto       Int             @map("id_paso_reto")
  url_evidencia      String          @db.Text
  comentario         String?         @db.Text
  created_at         DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("PASO_EVIDENCIA")
  @@schema("Estudiante")
}

model EstudianteHabilidad {
  id_estudiante_habilidad Int        @id @default(autoincrement()) @map("id_estudiante_habilidad")
  id_estudiante          Int        @map("id_estudiante")
  id_habilidad           Int        @map("id_habilidad")
  nivel_dominio          String     @map("nivel_dominio") @db.VarChar(50)
  
  estudiante             Estudiante @relation(fields: [id_estudiante], references: [id_estudiante], onDelete: Cascade)
  habilidad              Habilidad  @relation(fields: [id_habilidad], references: [id_habilidad], onDelete: Restrict)

  @@unique([id_estudiante, id_habilidad], map: "UQ_ESTUDIANTE_HABILIDAD_COMPUESTA")
  @@map("ESTUDIANTE_HABILIDAD")
  @@schema("Estudiante")
}

